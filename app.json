{
  "expo": {
    "name": "Staxz",
    "slug": "staxz",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "staxz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.staxz.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to upload portfolio photos",
        "NSPhotoLibraryUsageDescription": "Used to select portfolio photos",
        "NSLocationWhenInUseUsageDescription": "Used to find providers near you"
      }
    },
    "android": {
      "package": "com.staxz.app",
      "adaptiveIcon": {
        "backgroundColor": "#7B4FA6"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#7B4FA6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9e07bfc3-af81-424c-85d4-e7b5b3d844b1"
      }
    },
    "owner": "make_d_great"
  }
}
