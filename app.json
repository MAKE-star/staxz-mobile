{
  "expo": {
    "name": "Staxz",
    "slug": "staxz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "staxz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.staxz.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to upload portfolio photos",
        "NSPhotoLibraryUsageDescription": "Used to select portfolio photos",
        "NSLocationWhenInUseUsageDescription": "Used to find providers near you"
      }
    },
    "android": {
      "package": "com.staxz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7B4FA6"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        { "color": "#7B4FA6" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}